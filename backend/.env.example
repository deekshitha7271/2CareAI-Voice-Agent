# --- SERVER CONFIGURATION ---
HOST=0.0.0.0
PORT=8000
LATENCY_LOGGING=True

# --- AI & VOICE API KEYS ---
# Get this from https://console.deepgram.com/ (For < 250ms Streaming STT)
DEEPGRAM_API_KEY="your_deepgram_api_key_here"

# Get this from https://console.groq.com/ (For Lightning Fast Llama-3 Reasoning)
GROQ_API_KEY="your_groq_api_key_here"

# Get this from https://play.cartesia.ai/ (For Ultra-Low Latency TTS)
CARTESIA_API_KEY="your_cartesia_api_key_here"

# Fallback LLM (Optional if using Groq)
OPENAI_API_KEY="your_openai_api_key_here"

# --- DATABASES ---
# Local Redis connection string (used for exact-millisecond pessimistic slot locking)
REDIS_URL="redis://localhost:6379/0"

# Local MongoDB connection string (used for patients, doctors, and storing appointments)
MONGODB_URL="mongodb://localhost:27017/"
